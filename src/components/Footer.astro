---
import SocialLinks from "./SocialLinks.astro";
---

<footer
  class="bg-linear-90 from-aquamarine via-lilac to-salmon pt-8 pb-6 dark:from-teal dark:via-eggplant dark:to-rose"
>
  <div class="flex flex-col items-center gap-2">
    <SocialLinks />
    <div class="mt-4">
      <img
        src="/images/signature-dark.png"
        alt="Handwritten text displaying 'Made with love by Angela Zheng'"
        width={200}
        loading="eager"
        class="block dark:hidden"
      />
      <img
        src="/images/signature-light.png"
        alt="Handwritten text displaying 'Made with love by Angela Zheng'"
        width={200}
        loading="eager"
        class="hidden dark:block"
      />
    </div>
    <div class="text-center text-sm italic">
      This website is <a
        href="https://github.com/angelazheng96/angelazheng"
        target="_blank"
        class="font-medium hover:text-eggplant hover:decoration-eggplant dark:hover:text-lilac dark:hover:decoration-lilac"
      >
        open source</a
      >!
    </div>
  </div>
</footer>
