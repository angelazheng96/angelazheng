---
import "../styles/global.css";

const { title, authors, conference, conferenceLink, location, date, links } =
  Astro.props;

const linkEntries = (() => {
  if (!links) {
    return [];
  }

  if (links instanceof Map) {
    return Array.from(links.entries());
  }

  if (Array.isArray(links)) {
    return links
      .filter((entry) => Array.isArray(entry) && entry.length >= 2)
      .map(([text, url]) => [String(text), String(url)]);
  }

  if (typeof links === "object") {
    return Object.entries(links).map(([text, url]) => [text, String(url)]);
  }

  return [];
})();
---

<div class="mb-6">
  <h2>{title}</h2>
  <p class="font-medium">{authors}</p>
  <p>
    <a href={conferenceLink} target="_blank" rel="noopener noreferrer"
      >{conference}</a
    > | {date} | {location}
  </p>
  {
    linkEntries.length > 0 && (
      <p>
        {linkEntries.map(([text, url], index) => (
          <span>
            {index > 0 && " | "}
            {/* prettier-ignore */}
            <a href={url} target="_blank" rel="noopener noreferrer">{text}</a>
          </span>
        ))}
      </p>
    )
  }
</div>
